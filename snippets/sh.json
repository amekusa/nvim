{
  "(bash) $BASH_VERSINFO": {
    "body": "\\$BASH_VERSINFO",
    "prefix": "(bash) $BASH_VERSINFO"
  },
  "(bash) ${BASH_REMATCH[_]}": {
    "body": "\\${BASH_REMATCH[${1:1}]}",
    "prefix": "(bash) ${BASH_REMATCH[_]}"
  },
  "(bash) ${FUNCNAME[0]}": {
    "body": "\\${FUNCNAME[0]}",
    "prefix": "(bash) ${FUNCNAME[0]}"
  },
  "(zsh) $ZSH_VERSION": {
    "body": "\\$ZSH_VERSION",
    "prefix": "(zsh) $ZSH_VERSION"
  },
  ":array + local -a _=(_)": {
    "body": "local -a ${1:arr}=($2)",
    "prefix": [
      ":array",
      "local -a _=(_)"
    ]
  },
  ":array item + :array element": {
    "body": "\\${${1:arr}[${2:0}]}",
    "prefix": [
      ":array item",
      ":array element"
    ]
  },
  ":array length": {
    "body": "\\${#${1:arr}[@]}",
    "prefix": ":array length"
  },
  ":case + case _ in ... esac": {
    "body": [
      "case \"\\$${1:var}\" in",
      "$2) $0;;",
      "esac"
    ],
    "prefix": [
      ":case",
      "case _ in ... esac"
    ]
  },
  ":case args": {
    "body": [
      "case \"\\$1\" in",
      "-h|--help)",
      "\t$0",
      "\treturn 0",
      "\t;;",
      "-*)",
      "\techo \"Invalid argument: '\\$1'\" >&2",
      "\treturn 1",
      "\t;;",
      "esac"
    ],
    "prefix": ":case args"
  },
  ":colors + :ansi": {
    "body": [
      "if [ -t 1 ] && [ -z \"$NO_COLOR\" ]; then",
      "\tred=$'\\e[0;31m'",
      "\tgrn=$'\\e[0;32m'",
      "\tylw=$'\\e[0;33m'",
      "\tmag=$'\\e[0;35m'",
      "\tcyn=$'\\e[0;36m'",
      "\tbld=$'\\e[1m'",
      "\tund=$'\\e[4m'",
      "\trst=$'\\e[0m'",
      "fi",
      "_ok() {",
      "\techo -e \"[${grn}OK${rst}] $*\"",
      "}",
      "_warn() {",
      "\techo -e \"[${ylw}WARN${rst}] $*\"",
      "}",
      "_error() {",
      "\techo -e \"[${red}ERROR${rst}] $*\" >&2; return 1",
      "}"
    ],
    "prefix": [
      ":colors",
      ":ansi"
    ]
  },
  ":cond not empty": {
    "body": "[ -n \"$1\" ]",
    "prefix": ":cond not empty"
  },
  ":date hms": {
    "body": "date +'%H:%M:%S'",
    "prefix": ":date hms"
  },
  ":date seconds": {
    "body": "date +%s",
    "prefix": ":date seconds"
  },
  ":date ymd": {
    "body": "date +%F",
    "prefix": ":date ymd"
  },
  ":date ymd hms": {
    "body": "date +'%F %H:%M:%S'",
    "prefix": ":date ymd hms"
  },
  ":echo var + :debug": {
    "body": "echo \"[DBG] ${1:var}: \\$$1\"",
    "prefix": [
      ":echo var",
      ":debug"
    ]
  },
  ":for args": {
    "body": [
      "for ${1:arg} in \"\\$@\"; do",
      "\t$0",
      "done"
    ],
    "prefix": ":for args"
  },
  ":for array": {
    "body": [
      "for ${1:each} in \"${${2:arr}[@]}\"; do",
      "\t$0",
      "done"
    ],
    "prefix": ":for array"
  },
  ":for array index": {
    "body": [
      "for ${1:i} in \"\\${!${2:arr}[@]}\"; do",
      "\t$0\"\\${${2}[\\$${1}]}\"",
      "done"
    ],
    "prefix": ":for array index"
  },
  ":getopts + :args options": {
    "body": [
      "local opts",
      "while getopts '$1abc' opts; do",
      "\tcase \"\\$opts\" in",
      "\t$2a) flag_a=1 ;;",
      "\tb) flag_b=1 ;;",
      "\tc) flag_c=1 ;;",
      "\t?) exit 1 ;;",
      "\tesac",
      "done"
    ],
    "prefix": [
      ":getopts",
      ":args options"
    ]
  },
  ":has command + command -v _ &> /dev/null": {
    "body": "command -v \"${1:cmd}\" &> /dev/null",
    "prefix": [
      ":has command",
      "command -v _ &> /dev/null"
    ]
  },
  ":help + :usage": {
    "body": [
      "if [ $# -eq 0 ] || [ \"\\$1\" = \"--help\" ] || [ \"\\$1\" = \"-h\" ]; then",
      "\tcat <<- EOF",
      "\tUsage:",
      "\t  $0",
      "\tEOF",
      "\treturn 1",
      "fi"
    ],
    "prefix": [
      ":help",
      ":usage"
    ]
  },
  ":heredoc": {
    "body": [
      "cat <<- EOF",
      "$0",
      "EOF"
    ],
    "prefix": ":heredoc"
  },
  ":if + if _; then ... fi": {
    "body": [
      "if ${1:cond}; then",
      "\t$0",
      "fi"
    ],
    "prefix": [
      ":if",
      "if _; then ... fi"
    ]
  },
  ":if bash": {
    "body": [
      "if [ -n \"\\$BASH_VERSINFO\" ]; then",
      "\t$0",
      "fi"
    ],
    "prefix": ":if bash"
  },
  ":if zsh": {
    "body": [
      "if [ -n \"\\$ZSH_VERSION\" ]; then",
      "\t$0",
      "fi"
    ],
    "prefix": ":if zsh"
  },
  ":path extension": {
    "body": "\\${${1:path}##*.}",
    "prefix": ":path extension"
  },
  ":prompt": {
    "body": [
      "while true; do",
      "\tread -n 1 -p \"${1:msg}? (Y/N) \" ${2:answer}; echo",
      "\tcase \"$${2:answer}\" in",
      "\t[Yy])",
      "\t\t$3",
      "\t\t;;",
      "\t[Nn])",
      "\t\t$4",
      "\t\t;;",
      "\t*)",
      "\t\techo \"Type Y or N\"",
      "\tesac",
      "done"
    ],
    "prefix": ":prompt"
  },
  ":regex": {
    "body": "[[ \"$${1:var}\" =~ ${2:regex} ]]",
    "prefix": ":regex"
  },
  ":regex space + [[:space:]]": {
    "body": "[[:space:]]",
    "prefix": [
      ":regex space",
      "[[:space:]]"
    ]
  },
  ":shebang + #!/usr/bin/env _": {
    "body": "#!/usr/bin/env ${1:bash}",
    "prefix": [
      ":shebang",
      "#!/usr/bin/env _"
    ]
  },
  ":split into array + :string to array": {
    "body": "IFS='${1:sep}' read -ra ${2:arr} <<< \"\\$${3:str}\"",
    "prefix": [
      ":split into array",
      ":string to array"
    ]
  },
  ":substr offset": {
    "body": "\\${${1:str}:${2:offset}}",
    "prefix": ":substr offset"
  },
  ":substr offset + length": {
    "body": "\\${${1:str}:${2:offset}:${3:length}}",
    "prefix": ":substr offset + length"
  },
  ":substr remove from pattern": {
    "body": "\\${${1:str}%${2:from}*}",
    "prefix": ":substr remove from pattern"
  },
  ":substr remove from pattern (greed)": {
    "body": "\\${${1:str}%%${2:from}*}",
    "prefix": ":substr remove from pattern (greed)"
  },
  ":substr remove to pattern": {
    "body": "\\${${1:str}#*${2:to}}",
    "prefix": ":substr remove to pattern"
  },
  ":substr remove to pattern (greed)": {
    "body": "\\${${1:str}##*${2:to}}",
    "prefix": ":substr remove to pattern (greed)"
  },
  ":suppress + :no output + &> /dev/null": {
    "body": "&> /dev/null",
    "prefix": [
      ":suppress",
      ":no output",
      "&> /dev/null"
    ]
  },
  ":to stderr": {
    "body": ">&2",
    "prefix": ":to stderr"
  },
  ":while args": {
    "body": [
      "while [ $# -gt 0 ]; do",
      "\t$0",
      "\tshift",
      "done"
    ],
    "prefix": ":while args"
  },
  ":while lines + :read lines": {
    "body": [
      "local IFS ${1:line}",
      "while IFS= read -r ${1}; do",
      "\t$0",
      "done < ${2:file}"
    ],
    "prefix": [
      ":while lines",
      ":read lines"
    ]
  },
  "local _": {
    "body": "local ${1:var}",
    "prefix": "local _"
  },
  "then ... fi": {
    "body": [
      "then",
      "\t$0",
      "fi"
    ],
    "prefix": "then ... fi"
  }
}
